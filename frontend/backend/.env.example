# ──────────────────────────────────────────────
# IELTS Daily Backend — Environment Variables
# Copy this to .env and fill in your keys.
# ──────────────────────────────────────────────

# ── AI Providers ──
# Priority: 1. Groq (Fastest) -> 2. NVIDIA (Fallback)
GROQ_API_KEY=your_groq_key_here
NVIDIA_API_KEY=your_nvidia_key_here

# ── Database ──
# Local: sqlite:///./ielts_daily.db (Default)
# Cloud: postgresql://user:pass@host:5432/db
DATABASE_URL=sqlite:///./ielts_daily.db

# ── Security ──
# Comma-separated list of allowed origins (Vercel, Localhost, etc.)
CORS_ORIGINS=http://localhost:8081,http://localhost:3000,exp://

# ── JWT Auth ──
SECRET_KEY=generate_a_random_string_for_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
